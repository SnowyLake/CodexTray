<Window x:Class="CodexTray.App.TrayPopupWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CodexTray.Core;assembly=CodexTray.Core"
        xmlns:local="clr-namespace:CodexTray.App"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{x:Static core:CodexTrayDefaults.AppName}"
        Width="380"
        Height="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#01131A1C"
        Topmost="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        ThemeMode="System">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <sys:Int32 x:Key="ToolTipInitialShowDelay">120</sys:Int32>
            <sys:Int32 x:Key="ToolTipShowDuration">6000</sys:Int32>
            <sys:String x:Key="PluginDetectingText">Detecting...</sys:String>

            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="FontFamily" Value="Segoe UI" />
            </Style>

            <!-- Secondary caption under a settings row title (shared tooltip timing) -->
            <Style x:Key="SettingsRowSubtitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
            </Style>

            <!-- Rotating glyph used while plugin auto detect runs -->
            <Style x:Key="DetectSpinnerStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SettingsRowSubtitleStyle}">
                <Setter Property="Text" Value="&#xE72C;" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsVisible" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard Name="SpinStoryboard">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:0.9"
                                                     RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Rotating refresh glyph used while home refresh runs -->
            <Style x:Key="RefreshSpinnerGlyphStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Text" Value="&#xE72C;" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Name="RefreshSpinStoryboard">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:0.9"
                                                     RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="RefreshSpinStoryboard" />
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Icon button (shared: home refresh + settings save) -->
            <!-- Subtle icon button: constant Primary glyph, background fills on hover/press -->
            <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background"
                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background"
                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Home ============ -->
            <Thickness x:Key="HomeSectionHeaderMargin">0,0,0,12</Thickness>
            <Thickness x:Key="HomeSectionHeaderSpacedMargin">0,22,0,10</Thickness>

            <Style x:Key="HomeSectionHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="{StaticResource HomeSectionHeaderMargin}" />
            </Style>

            <Style x:Key="HomeSectionHeaderSpacedStyle"
                   BasedOn="{StaticResource HomeSectionHeaderStyle}"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="Margin" Value="{StaticResource HomeSectionHeaderSpacedMargin}" />
            </Style>

            <!-- ============ Settings: native Fluent controls ============ -->
            <!-- Only layout tweaks; templates stay Fluent so inputs work. -->
            <Thickness x:Key="SettingsSectionHeaderMargin">0,0,0,10</Thickness>
            <Thickness x:Key="SettingsSectionHeaderSpacedMargin">0,28,0,10</Thickness>
            <Thickness x:Key="SettingsRowMargin">0,0,0,6</Thickness>
            <Thickness x:Key="SettingsSectionEndMargin">0,0,0,6</Thickness>
            <Thickness x:Key="SettingsLastRowMargin">0,0,0,8</Thickness>

            <Style x:Key="SettingsTextBoxStyle"
                   BasedOn="{StaticResource {x:Type TextBox}}"
                   TargetType="{x:Type TextBox}">
                <Setter Property="Height" Value="34" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
            </Style>

            <Style x:Key="SettingsComboBoxStyle"
                   BasedOn="{StaticResource {x:Type ComboBox}}"
                   TargetType="{x:Type ComboBox}">
                <Setter Property="Height" Value="34" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
            </Style>

            <Style x:Key="SettingsRowGridStyle" TargetType="{x:Type Grid}">
                <Setter Property="Margin" Value="{StaticResource SettingsRowMargin}" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
            </Style>

            <Style x:Key="SettingsSectionHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="{StaticResource SettingsSectionHeaderMargin}" />
            </Style>

            <!-- Header for non-first sections: extra top gap replaces the removed divider -->
            <Style x:Key="SettingsSectionHeaderSpacedStyle"
                   BasedOn="{StaticResource SettingsSectionHeaderStyle}"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="Margin" Value="{StaticResource SettingsSectionHeaderSpacedMargin}" />
            </Style>

            <Style x:Key="SettingsRowTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
            </Style>

            <!-- Segmented nav tab -->
            <Style x:Key="TabButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="80" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="{StaticResource ToolTipInitialShowDelay}" />
                <Setter Property="ToolTipService.ShowDuration" Value="{StaticResource ToolTipShowDuration}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="TabChrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="11"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="HomeTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SettingsTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ApiTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsApiSelected}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Quota progress bar -->
            <Style x:Key="QuotaProgressBarStyle" TargetType="{x:Type ProgressBar}">
                <Setter Property="Height" Value="6" />
                <Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ProgressBar}">
                            <Grid x:Name="TemplateRoot">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="3" />
                                <Border x:Name="PART_Track"
                                        Background="Transparent"
                                        CornerRadius="3" />
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="3" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="0"
            Padding="24,22,24,20"
            CornerRadius="0"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===================== HOME ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsHomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Codex"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="26"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                            <Border MinWidth="52"
                                    Height="22"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Padding="11,0"
                                    CornerRadius="11"
                                    Background="{Binding PlanBadgeBrush}">
                                <TextBlock Text="{Binding PlanDisplay}"
                                           Foreground="#FFFFFF"
                                           FontWeight="Normal"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Command="{Binding RefreshCommand}"
                                ToolTip="Refresh"
                                Style="{StaticResource IconButtonStyle}">
                            <TextBlock Style="{StaticResource RefreshSpinnerGlyphStyle}" />
                        </Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Margin="2,6,0,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding StatusDotBrush}" />
                        <TextBlock Text="{Binding UpdatedAtDisplay}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Quota list -->
                <ScrollViewer Grid.Row="1"
                              Margin="0,24,-8,0"
                              Padding="0,0,8,0"
                              VerticalScrollBarVisibility="Hidden">
                    <StackPanel VerticalAlignment="Top"
                                Grid.IsSharedSizeScope="True">
                    <TextBlock Text="Usage"
                               Style="{StaticResource HomeSectionHeaderStyle}" />

                    <!-- 5 hour -->
                    <StackPanel Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding FiveHourQuota.Title}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="13.5"
                                       FontWeight="Medium" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FiveHourQuota.PercentText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="Normal" />
                        </Grid>
                        <ProgressBar Margin="0,9,0,0"
                                     Maximum="100"
                                     Value="{Binding FiveHourQuota.RemainingPercent, Mode=OneWay}"
                                     Foreground="{Binding FiveHourQuota.AccentBrush}"
                                     Style="{StaticResource QuotaProgressBarStyle}" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,5,0,0">
                            <TextBlock Text="&#xE823;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FiveHourQuota.ResetText}" Value="unknown">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding FiveHourQuota.ResetText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Seven day -->
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SevenDayQuota.Title}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="13.5"
                                       FontWeight="Medium" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SevenDayQuota.PercentText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="Normal" />
                        </Grid>
                        <ProgressBar Margin="0,9,0,0"
                                     Maximum="100"
                                     Value="{Binding SevenDayQuota.RemainingPercent, Mode=OneWay}"
                                     Foreground="{Binding SevenDayQuota.AccentBrush}"
                                     Style="{StaticResource QuotaProgressBarStyle}" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,5,0,0">
                            <TextBlock Text="&#xE823;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SevenDayQuota.ResetText}" Value="unknown">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding SevenDayQuota.ResetText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Reset Credits"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="13.5"
                                       FontWeight="Normal" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ResetCreditsDisplay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="13.5"
                                       FontWeight="Normal" />
                        </Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,5,0,0">
                            <TextBlock Text="{Binding ResetCreditsResetTime}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Token Cost"
                               Style="{StaticResource HomeSectionHeaderSpacedStyle}"
                               Visibility="{Binding IsTokenCostVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Grid Visibility="{Binding IsTokenCostVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Today"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowTodayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Column="1"
                                   Margin="0,0,0,12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowTodayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="TodayTokenCostDisplay.Cost" />
                                    <Binding Path="TodayTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="1"
                                   Text="Yesterday"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowYesterdayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,0,0,12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowYesterdayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="YesterdayTokenCostDisplay.Cost" />
                                    <Binding Path="YesterdayTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="2"
                                   Text="Week"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowWeekTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,0,0,12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowWeekTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="WeekTokenCostDisplay.Cost" />
                                    <Binding Path="WeekTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="3"
                                   Text="Month"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowMonthTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,0,0,12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowMonthTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="MonthTokenCostDisplay.Cost" />
                                    <Binding Path="MonthTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="4"
                                   Text="Last 7 Days"
                                   Margin="0,0,0,12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowSevenDayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,0,0,12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowSevenDayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="SevenDayTokenCostDisplay.Cost" />
                                    <Binding Path="SevenDayTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="5"
                                   Text="Last 30 Days"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13.5"
                                   FontWeight="Medium"
                                   Visibility="{Binding ShowThirtyDayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13.5"
                                   Visibility="{Binding ShowThirtyDayTokenCost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="ThirtyDayTokenCostDisplay.Cost" />
                                    <Binding Path="ThirtyDayTokenCostDisplay.Tokens" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- ===================== APIs ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsApiVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="APIs"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="26"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button VerticalAlignment="Center"
                                    Command="{Binding AddApiMonitorCommand}"
                                    Content="&#xE710;"
                                    ToolTip="Add API"
                                    Style="{StaticResource IconButtonStyle}" />
                            <Button VerticalAlignment="Center"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="Refresh"
                                    Style="{StaticResource IconButtonStyle}">
                                <TextBlock Style="{StaticResource RefreshSpinnerGlyphStyle}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="2,6,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding ApiMonitorStatusDotBrush}"
                                 Visibility="{Binding HasApiMonitorStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{Binding ApiMonitorStatusText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,-8,0"
                              Padding="0,0,8,0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,36,0,20"
                                   Text="No APIs are monitored yet."
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13"
                                   Visibility="{Binding IsApiEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <ItemsControl ItemsSource="{Binding ApiMonitors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            CornerRadius="10"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="7"
                                                                 Height="7"
                                                                 Margin="0,0,6,0"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{Binding StatusDotBrush}"
                                                                 ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                                                 ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                                                 ToolTip="{Binding StatusText}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                                                   ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                                                   ToolTip="{Binding StatusText}" />
                                                    </Grid>
                                                    <StackPanel Grid.Row="0"
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                        <Button Width="30"
                                                                Height="30"
                                                                Command="{Binding DataContext.MoveApiMonitorUpCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE74A;"
                                                                ToolTip="Move up"
                                                                Style="{StaticResource IconButtonStyle}" />
                                                        <Button Width="30"
                                                                Height="30"
                                                                Command="{Binding DataContext.MoveApiMonitorDownCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE74B;"
                                                                ToolTip="Move down"
                                                                Style="{StaticResource IconButtonStyle}" />
                                                        <Button Width="30"
                                                                Height="30"
                                                                Command="{Binding ToggleEditingCommand}"
                                                                Content="&#xE713;"
                                                                ToolTip="Settings"
                                                                Style="{StaticResource IconButtonStyle}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding PrimaryDisplayLabel}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               Text="{Binding BalanceDisplay}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               FontSize="13" />
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Visibility="{Binding HasSecondaryDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding SecondaryDisplayLabel}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="12" />
                                                        <TextBlock Margin="8,0,0,0"
                                                                   Text="{Binding UsedDisplay}"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                   FontSize="13" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Provider settings"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold" />
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal">
                                                        <Button Width="30"
                                                                Height="30"
                                                                Command="{Binding DataContext.RemoveApiMonitorCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                CommandParameter="{Binding}"
                                                                Content="&#xE74D;"
                                                                Style="{StaticResource IconButtonStyle}" />
                                                        <Button Width="30"
                                                                Height="30"
                                                                Command="{Binding ToggleEditingCommand}"
                                                                Content="&#xE73E;"
                                                                Style="{StaticResource IconButtonStyle}" />
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Margin="0,12,0,5"
                                                           Text="Provider"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" />
                                                <ComboBox ItemsSource="{Binding ProviderOptions}"
                                                          SelectedItem="{Binding Provider}"
                                                          Style="{StaticResource SettingsComboBoxStyle}" />

                                                <TextBlock Margin="0,10,0,5"
                                                           Text="Display name"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           FontSize="12" />
                                                <TextBox Text="{Binding Name}"
                                                         Style="{StaticResource SettingsTextBoxStyle}" />

                                                <StackPanel Visibility="{Binding IsGrok, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Margin="0,12,0,5"
                                                               Text="OAuth source"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" />
                                                    <ComboBox ItemsSource="{Binding GrokOAuthSourceOptions}"
                                                              SelectedItem="{Binding GrokOAuthSource}"
                                                              Style="{StaticResource SettingsComboBoxStyle}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="Reads the local OAuth session. Tokens are not stored here."
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Visibility="{Binding IsGrok, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    <TextBlock Margin="0,12,0,5"
                                                               Text="Base URL"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" />
                                                    <TextBox Text="{Binding BaseUrl}"
                                                             Style="{StaticResource SettingsTextBoxStyle}" />

                                                    <TextBlock Margin="0,10,0,5"
                                                               Text="API key / access token"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="12" />
                                                    <TextBox Text="{Binding ApiKey}"
                                                             Style="{StaticResource SettingsTextBoxStyle}" />

                                                    <StackPanel Visibility="{Binding IsNewApi, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Margin="0,10,0,5"
                                                                   Text="User ID"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="12" />
                                                        <TextBox Text="{Binding UserId}"
                                                                 Style="{StaticResource SettingsTextBoxStyle}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ===================== SETTINGS ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: aligned with Home (left title + right button) -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Settings"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="26"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Command="{Binding SaveSettingsCommand}"
                                Content="&#xE74E;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="Save"
                                Style="{StaticResource IconButtonStyle}" />
                    </Grid>
                    <TextBlock Margin="2,6,0,0"
                               Text="{Binding SettingsStatusText}"
                               Foreground="{Binding SettingsStatusBrush}"
                               FontSize="12"
                               FontWeight="Medium"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,-8,0"
                              Padding="0,0,8,0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- General -->
                        <TextBlock Text="General"
                                   Style="{StaticResource SettingsSectionHeaderStyle}" />

                        <Grid ToolTip="Unit: minutes"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Refresh interval"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <local:NumericUpDown Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                                 ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                                 ToolTip="Unit: minutes"
                                                 Minimum="{x:Static core:CodexTrayDefaults.MinimumRefreshIntervalMinutes}"
                                                 Maximum="{x:Static core:CodexTrayDefaults.MaximumRefreshIntervalMinutes}"
                                                 DefaultValue="{x:Static core:CodexTrayDefaults.RefreshIntervalMinutes}"
                                                 Value="{Binding RefreshIntervalText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </Grid>

                        <Grid Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Start with Windows"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <CheckBox Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                      ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                      IsChecked="{Binding StartWithWindows}"
                                      ToolTip="Start with Windows" />
                        </Grid>

                        <Grid ToolTip="Show resets as absolute time (5-Hour as HH:mm, 7-Day and Grok as MM-dd) instead of a countdown"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Resets use absolute time"
                                       ToolTip="Show resets as absolute time (5-Hour as HH:mm, 7-Day and Grok as MM-dd) instead of a countdown"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <CheckBox Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                      ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                      IsChecked="{Binding UseAbsoluteResetTime}"
                                      ToolTip="Show resets as absolute time (5-Hour as HH:mm, 7-Day and Grok as MM-dd) instead of a countdown" />
                        </Grid>

                        <Grid Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Token Cost items"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <Button Grid.Column="1"
                                    Height="34"
                                    HorizontalAlignment="Stretch"
                                    Padding="11,0"
                                    HorizontalContentAlignment="Stretch"
                                    Click="OpenTokenCostItemsMenu">
                                <Grid>
                                    <TextBlock Text="{Binding TokenCostItemsDisplay}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="&#xE70D;"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" />
                                </Grid>
                                <Button.ContextMenu>
                                    <ContextMenu MinWidth="140"
                                                 Placement="Bottom"
                                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Today"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowTodayTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                        <MenuItem Header="Yesterday"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowYesterdayTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                        <MenuItem Header="Week"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowWeekTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                        <MenuItem Header="Month"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowMonthTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                        <MenuItem Header="Last 7 Days"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowSevenDayTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                        <MenuItem Header="Last 30 Days"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding ShowThirtyDayTokenCost, Mode=TwoWay}"
                                                  StaysOpenOnClick="True" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>

                        <Grid Margin="{StaticResource SettingsSectionEndMargin}"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Token unit"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <ComboBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding TokenUnitOptions}"
                                      SelectedItem="{Binding TokenUnit, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingsComboBoxStyle}" />
                        </Grid>

                        <!-- Appearance -->
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource SettingsSectionHeaderSpacedStyle}" />

                        <Grid Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <ComboBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding ThemeModeOptions}"
                                      SelectedItem="{Binding ThemeMode, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingsComboBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Acrylic blur"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <CheckBox Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                      ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                      IsChecked="{Binding AcrylicEnabled}"
                                      ToolTip="Acrylic blur" />
                        </Grid>

                        <Grid Margin="{StaticResource SettingsSectionEndMargin}"
                              Style="{StaticResource SettingsRowGridStyle}"
                              Visibility="{Binding AcrylicEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Opacity"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <Slider VerticalAlignment="Center"
                                        Minimum="{Binding AcrylicOpacityMinimum, Mode=OneTime}"
                                        Maximum="{Binding AcrylicOpacityMaximum, Mode=OneTime}"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Value="{Binding AcrylicOpacityPercent, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding AcrylicOpacityDisplay}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </Grid>
                        </Grid>

                        <!-- Plugins -->
                        <TextBlock Text="Plugins"
                                   Style="{StaticResource SettingsSectionHeaderSpacedStyle}" />

                        <Grid Margin="{StaticResource SettingsRowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="LiteMonitor"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <Grid Margin="0,2,8,0">
                                    <TextBlock Text="{Binding LiteMonitorDirDisplay}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LiteMonitorDirDisplay}"
                                               Style="{StaticResource SettingsRowSubtitleStyle}"
                                               Visibility="{Binding IsDetectingLiteMonitor, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsDetectingLiteMonitor, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource DetectSpinnerStyle}" />
                                        <TextBlock Text="{StaticResource PluginDetectingText}"
                                                   Margin="6,0,0,0"
                                                   Style="{StaticResource SettingsRowSubtitleStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseLiteMonitorCommand}"
                                    Content="&#xE8B7;"
                                    ToolTip="Browse"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsLiteMonitorActionsEnabled}"
                                    Style="{StaticResource IconButtonStyle}" />
                            <Button Grid.Column="2"
                                    Command="{Binding AutoDetectLiteMonitorCommand}"
                                    Content="&#xE721;"
                                    ToolTip="Auto detect"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsLiteMonitorActionsEnabled}"
                                    Style="{StaticResource IconButtonStyle}" />
                            <Button Grid.Column="3"
                                     Command="{Binding InstallLiteMonitorPluginCommand}"
                                     Content="&#xE896;"
                                      ToolTip="Setup"
                                      Margin="4,0,0,0"
                                      IsEnabled="{Binding IsLiteMonitorActionsEnabled}"
                                      Style="{StaticResource IconButtonStyle}" />
                        </Grid>

                        <Grid Margin="{StaticResource SettingsSectionEndMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="TrafficMonitor"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <Grid Margin="0,2,8,0">
                                    <TextBlock Text="{Binding TrafficMonitorDirDisplay}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding TrafficMonitorDirDisplay}"
                                               Style="{StaticResource SettingsRowSubtitleStyle}"
                                               Visibility="{Binding IsDetectingTrafficMonitor, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsDetectingTrafficMonitor, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource DetectSpinnerStyle}" />
                                        <TextBlock Text="{StaticResource PluginDetectingText}"
                                                   Margin="6,0,0,0"
                                                   Style="{StaticResource SettingsRowSubtitleStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseTrafficMonitorCommand}"
                                    Content="&#xE8B7;"
                                    ToolTip="Browse"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsTrafficMonitorActionsEnabled}"
                                    Style="{StaticResource IconButtonStyle}" />
                            <Button Grid.Column="2"
                                    Command="{Binding AutoDetectTrafficMonitorCommand}"
                                    Content="&#xE721;"
                                    ToolTip="Auto detect"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsTrafficMonitorActionsEnabled}"
                                    Style="{StaticResource IconButtonStyle}" />
                            <Button Grid.Column="3"
                                     Command="{Binding InstallTrafficMonitorPluginCommand}"
                                     Content="&#xE896;"
                                      ToolTip="Setup"
                                      Margin="4,0,0,0"
                                      IsEnabled="{Binding IsTrafficMonitorActionsEnabled}"
                                      Style="{StaticResource IconButtonStyle}" />
                        </Grid>

                        <Grid Margin="{StaticResource SettingsSectionEndMargin}"
                              ToolTip="Append reset countdown after the percentage in monitor plugins"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show reset time"
                                       ToolTip="Append reset countdown after the percentage in monitor plugins"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <CheckBox Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                      ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                      IsChecked="{Binding ShowResetTimeInPlugins}"
                                      ToolTip="Append reset countdown after the percentage in monitor plugins" />
                        </Grid>

                        <!-- Advanced -->
                        <TextBlock Text="Advanced"
                                   Style="{StaticResource SettingsSectionHeaderSpacedStyle}" />

                        <Grid Margin="{StaticResource SettingsLastRowMargin}"
                              ToolTip="{Binding ServiceStatus}"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="HTTP port"
                                       ToolTip="{Binding ServiceStatus}"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <local:NumericUpDown Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 ToolTipService.InitialShowDelay="{StaticResource ToolTipInitialShowDelay}"
                                                 ToolTipService.ShowDuration="{StaticResource ToolTipShowDuration}"
                                                 ToolTip="{Binding ServiceStatus}"
                                                 Minimum="{x:Static core:CodexTrayDefaults.MinimumPort}"
                                                 Maximum="{x:Static core:CodexTrayDefaults.MaximumPort}"
                                                 DefaultValue="{x:Static core:CodexTrayDefaults.Port}"
                                                 Value="{Binding PortText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </Grid>

                        <!-- About -->
                        <TextBlock Text="About"
                                   Style="{StaticResource SettingsSectionHeaderSpacedStyle}" />

                        <Grid Margin="{StaticResource SettingsLastRowMargin}"
                              Style="{StaticResource SettingsRowGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AppVersion, StringFormat=CodexTray · Version {0}}"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <Button Grid.Column="1"
                                    Command="{Binding ShowAboutCommand}"
                                    Content="&#xE72A;"
                                    ToolTip="Open About"
                                    Style="{StaticResource IconButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- ===================== ABOUT ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsAboutVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="About"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontSize="26"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Command="{Binding ShowSettingsCommand}"
                            Content="&#xE72B;"
                            ToolTip="Back to Settings"
                            Style="{StaticResource IconButtonStyle}" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,30,0,0">
                        <Border Width="82"
                                Height="82"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="20">
                            <Image Width="72"
                                   Height="72"
                                   Source="pack://siteoforigin:,,,/Resources/icon.png" />
                        </Border>
                        <TextBlock Margin="0,16,0,0"
                                   Text="CodexTray"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding AppVersion, StringFormat=Version {0}}"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />
                        <TextBlock Margin="18,12,18,28"
                                   Text="A lightweight Windows tray monitor for Codex usage and API balances."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />

                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="13">
                                <Hyperlink Command="{Binding OpenRepositoryCommand}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           ToolTip="Open GitHub repository">
                                    <Hyperlink.TextDecorations>
                                        <TextDecorationCollection>
                                            <TextDecoration Location="Underline"
                                                            PenOffset="2"
                                                            PenOffsetUnit="Pixel"
                                                            PenThicknessUnit="Pixel">
                                                <TextDecoration.Pen>
                                                    <Pen Brush="{DynamicResource TextFillColorSecondaryBrush}"
                                                         Thickness="1">
                                                        <Pen.DashStyle>
                                                            <DashStyle Dashes="1,2" />
                                                        </Pen.DashStyle>
                                                    </Pen>
                                                </TextDecoration.Pen>
                                            </TextDecoration>
                                        </TextDecorationCollection>
                                    </Hyperlink.TextDecorations>
                                    <Run Text="GitHub Repository" />
                                    <Run Text=" &#xE8A7;"
                                         FontFamily="Segoe MDL2 Assets"
                                         FontSize="12" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="MIT License · Copyright © 2026 SnowyLake"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="11.5" />
                </Grid>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="1"
                  Margin="0,18,0,0"
                  Visibility="{Binding IsAboutVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding ShowHomeCommand}"
                            Content="&#xE80F;"
                            ToolTip="Home"
                            Style="{StaticResource HomeTabButtonStyle}" />
                    <Button Command="{Binding ShowApiCommand}"
                            Content="&#xE774;"
                            ToolTip="APIs"
                            Style="{StaticResource ApiTabButtonStyle}" />
                    <Button Command="{Binding ShowSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Settings"
                            Style="{StaticResource SettingsTabButtonStyle}" />
                </StackPanel>
            </Grid>

            <!-- In-window modal -->
            <Grid Grid.RowSpan="2"
                  Panel.ZIndex="1"
                  Visibility="{Binding IsInAppDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="Transparent" />
                <Border Width="300"
                        MaxHeight="460"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="{Binding InAppDialogTitle}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <ScrollViewer MaxHeight="260"
                                      Margin="0,12,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding InAppDialogMessage}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                        <StackPanel Margin="0,20,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Command="{Binding DismissInAppDialogCommand}"
                                    Content="{Binding InAppDialogSecondaryButtonText}"
                                    Margin="0,0,8,0"
                                    MinWidth="76"
                                    Visibility="{Binding HasInAppDialogSecondaryButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Command="{Binding ConfirmInAppDialogCommand}"
                                    Content="{Binding InAppDialogPrimaryButtonText}"
                                    IsDefault="True"
                                    MinWidth="76" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

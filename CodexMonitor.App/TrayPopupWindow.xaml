<Window x:Class="CodexMonitor.App.TrayPopupWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CodexMonitor.Core;assembly=CodexMonitor.Core"
        xmlns:local="clr-namespace:CodexMonitor.App"
        Title="{x:Static core:CodexMonitorDefaults.AppName}"
        Width="410"
        Height="588"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#01131A1C"
        Topmost="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        ThemeMode="System">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="FontFamily" Value="Segoe UI" />
            </Style>

            <!-- Icon button (shared: home refresh + settings save) -->
            <Style x:Key="RoundIconButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Settings: native Fluent controls ============ -->
            <!-- Only layout tweaks; templates stay Fluent so inputs work. -->
            <Style x:Key="SettingsTextBoxStyle"
                   BasedOn="{StaticResource {x:Type TextBox}}"
                   TargetType="{x:Type TextBox}">
                <Setter Property="Height" Value="34" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsComboBoxStyle"
                   BasedOn="{StaticResource {x:Type ComboBox}}"
                   TargetType="{x:Type ComboBox}">
                <Setter Property="Height" Value="34" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsGlyphButtonStyle"
                   BasedOn="{StaticResource {x:Type Button}}"
                   TargetType="{x:Type Button}">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="34" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="8,0,0,0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <Style x:Key="SettingsPrimaryButtonStyle"
                   BasedOn="{StaticResource SettingsGlyphButtonStyle}"
                   TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.AccentColorBrushKey}}" />
                <Setter Property="Foreground" Value="#FFFFFF" />
            </Style>

            <Style x:Key="SettingsSectionHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="SettingsRowTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsRowMetaStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Segmented nav tab -->
            <Style x:Key="TabButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="80" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="TabChrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="11"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="HomeTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SettingsTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="16" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Quota progress bar -->
            <Style x:Key="QuotaProgressBarStyle" TargetType="{x:Type ProgressBar}">
                <Setter Property="Height" Value="6" />
                <Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ProgressBar}">
                            <Grid x:Name="TemplateRoot">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="3" />
                                <Border x:Name="PART_Track"
                                        Background="Transparent"
                                        CornerRadius="3" />
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="3" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="0"
            Padding="24,22,24,20"
            CornerRadius="0"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===================== HOME ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsHomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Codex"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="26"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                            <Border MinWidth="52"
                                    Height="22"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Padding="11,0"
                                    CornerRadius="11"
                                    Background="{Binding PlanBadgeBrush}">
                                <TextBlock Text="{Binding PlanDisplay}"
                                           Foreground="#FFFFFF"
                                           FontWeight="Normal"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Command="{Binding RefreshCommand}"
                                Content="&#xE72C;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="Refresh"
                                Style="{StaticResource RoundIconButtonStyle}" />
                    </Grid>
                    <TextBlock Text="{Binding UpdatedAtDisplay}"
                               Margin="2,6,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <!-- Quota list -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Top"
                            Margin="0,24,0,0"
                            Grid.IsSharedSizeScope="True">
                    <TextBlock Text="Usage"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />

                    <!-- 5 hour -->
                    <StackPanel Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="QuotaTitleColumn" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FiveHourQuota.Title}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           FontSize="13.5"
                                           FontWeight="Medium" />
                                <TextBlock Grid.Column="1"
                                           Text=" | "
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13.5" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding FiveHourQuota.ResetText}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13.5" />
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FiveHourQuota.PercentText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="Normal" />
                        </Grid>
                        <ProgressBar Margin="0,9,0,0"
                                     Maximum="100"
                                     Value="{Binding FiveHourQuota.RemainingPercent, Mode=OneWay}"
                                     Foreground="{Binding FiveHourQuota.AccentBrush}"
                                     Style="{StaticResource QuotaProgressBarStyle}" />
                    </StackPanel>

                    <!-- Weekly -->
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="QuotaTitleColumn" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WeeklyQuota.Title}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           FontSize="13.5"
                                           FontWeight="Medium" />
                                <TextBlock Grid.Column="1"
                                           Text=" | "
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13.5" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding WeeklyQuota.ResetText}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13.5" />
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding WeeklyQuota.PercentText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="Normal" />
                        </Grid>
                        <ProgressBar Margin="0,9,0,0"
                                     Maximum="100"
                                     Value="{Binding WeeklyQuota.RemainingPercent, Mode=OneWay}"
                                     Foreground="{Binding WeeklyQuota.AccentBrush}"
                                     Style="{StaticResource QuotaProgressBarStyle}" />
                    </StackPanel>
                </StackPanel>

            </Grid>

            <!-- ===================== SETTINGS ===================== -->
            <Grid Grid.Row="0"
                  Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: aligned with Home (left title + right button) -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Settings"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="26"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Command="{Binding SaveSettingsCommand}"
                                Content="&#xE74E;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="Save"
                                Style="{StaticResource RoundIconButtonStyle}" />
                    </Grid>
                    <TextBlock Margin="2,6,0,0"
                               Text="{Binding SettingsStatusText}"
                               Foreground="{Binding SettingsStatusBrush}"
                               FontSize="12"
                               FontWeight="Medium"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,-8,0"
                              Padding="0,0,8,0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- General -->
                        <TextBlock Text="General"
                                   Style="{StaticResource SettingsSectionHeaderStyle}" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Refresh interval"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Minutes between updates"
                                           Style="{StaticResource SettingsRowMetaStyle}" />
                            </StackPanel>
                            <local:NumericUpDown Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 Minimum="{x:Static core:CodexMonitorDefaults.MinimumRefreshIntervalMinutes}"
                                                 Maximum="{x:Static core:CodexMonitorDefaults.MaximumRefreshIntervalMinutes}"
                                                 DefaultValue="{x:Static core:CodexMonitorDefaults.RefreshIntervalMinutes}"
                                                 Value="{Binding RefreshIntervalText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Start with Windows"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <CheckBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding StartWithWindows}"
                                      ToolTip="Start with Windows" />
                        </Grid>

                        <!-- Appearance -->
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource SettingsSectionHeaderStyle}" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <ComboBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding ThemeModeOptions}"
                                      SelectedItem="{Binding ThemeMode, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingsComboBoxStyle}" />
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Acrylic blur"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Translucent blurred window background"
                                           Style="{StaticResource SettingsRowMetaStyle}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AcrylicEnabled}"
                                      ToolTip="Acrylic blur" />
                        </Grid>

                        <Grid Margin="0,0,0,16"
                              Visibility="{Binding AcrylicEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Opacity"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Background opacity percent"
                                           Style="{StaticResource SettingsRowMetaStyle}" />
                            </StackPanel>
                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <Slider VerticalAlignment="Center"
                                        Minimum="{Binding AcrylicOpacityMinimum, Mode=OneTime}"
                                        Maximum="{Binding AcrylicOpacityMaximum, Mode=OneTime}"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        Value="{Binding AcrylicOpacityPercent, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding AcrylicOpacityDisplay}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </Grid>
                        </Grid>

                        <!-- Plugins -->
                        <TextBlock Text="Plugins"
                                   Style="{StaticResource SettingsSectionHeaderStyle}" />

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="LiteMonitor folder"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding LiteMonitorDir, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsTextBoxStyle}" />
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseLiteMonitorCommand}"
                                        Content="&#xE8B7;"
                                        ToolTip="Browse"
                                        Style="{StaticResource SettingsGlyphButtonStyle}" />
                                <Button Grid.Column="2"
                                        Command="{Binding AutoDetectLiteMonitorCommand}"
                                        Content="&#xE721;"
                                        ToolTip="Detect"
                                        Style="{StaticResource SettingsGlyphButtonStyle}" />
                                <Button Grid.Column="3"
                                        Command="{Binding InstallLiteMonitorPluginCommand}"
                                        Content="&#xE896;"
                                        ToolTip="Install"
                                        Style="{StaticResource SettingsPrimaryButtonStyle}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="TrafficMonitor folder"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource SettingsRowTitleStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding TrafficMonitorDir, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsTextBoxStyle}" />
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseTrafficMonitorCommand}"
                                        Content="&#xE8B7;"
                                        ToolTip="Browse"
                                        Style="{StaticResource SettingsGlyphButtonStyle}" />
                                <Button Grid.Column="2"
                                        Command="{Binding AutoDetectTrafficMonitorCommand}"
                                        Content="&#xE721;"
                                        ToolTip="Detect"
                                        Style="{StaticResource SettingsGlyphButtonStyle}" />
                                <Button Grid.Column="3"
                                        Command="{Binding InstallTrafficMonitorPluginCommand}"
                                        Content="&#xE896;"
                                        ToolTip="Install"
                                        Style="{StaticResource SettingsPrimaryButtonStyle}" />
                            </Grid>
                        </StackPanel>

                        <!-- Advanced -->
                        <TextBlock Text="Advanced"
                                   Style="{StaticResource SettingsSectionHeaderStyle}" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="HTTP port"
                                           Style="{StaticResource SettingsRowTitleStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding ServiceStatus}"
                                           Style="{StaticResource SettingsRowMetaStyle}" />
                            </StackPanel>
                            <local:NumericUpDown Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 Minimum="{x:Static core:CodexMonitorDefaults.MinimumPort}"
                                                 Maximum="{x:Static core:CodexMonitorDefaults.MaximumPort}"
                                                 DefaultValue="{x:Static core:CodexMonitorDefaults.Port}"
                                                 Value="{Binding PortText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding ShowHomeCommand}"
                            Content="&#xE80F;"
                            ToolTip="Home"
                            Style="{StaticResource HomeTabButtonStyle}" />
                    <Button Command="{Binding ShowSettingsCommand}"
                            Content="&#xE713;"
                            ToolTip="Settings"
                            Style="{StaticResource SettingsTabButtonStyle}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
